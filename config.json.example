{
  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "read_timeout": 30,   #seconds
    "write_timeout": 30,  #seconds
    "idle_timeout": 120,  #seconds
    "tls_cert_file": "",
    "tls_key_file": ""
  },
  "database":  {
    "driver": "postgres",
    "host": "localhost",
    "port": 5432,
    "user": "postgres",
    "password": "111222333",
    "dbname": "kyc_blockchain",
    "sslmode":  "disable",
    "max_open_conns": 25,
    "max_idle_conns": 5,
    "conn_max_lifetime": 300
  },
  "jwt": {
    "secret_key": "your-super-secret-key-change-in-production-min-32-chars",
    "token_expiry": 3600,     #seconds
    "refresh_expiry": 86400,  #seconds
    "issuer": "kyc-blockchain"
  },
  "crypto": {
    "algorithm": "ECDSA",
    "key_size": 256,
    "aes_key_size": 32,
    "key_store_path": "./keys"
    "encryption_key": "your-32-byte-secret-key-here123"
  },
  "consensus":  {
    "type": "pbft",
    "node_id": "node1",
    "nodes": ["node1", "node2", "node3", "node4"],
    "election_timeout": 1000,   #milliseconds
    "heartbeat_interval": 150   #milliseconds
  },
  "blockchain": {
    "difficulty": 2,
    "max_tx_per_block": 100,
    "block_interval": 10
  },
  "verification": {
    "enabled": true,
    "auto_approve": true,
    "min_score": 80.0,
    "provider":  "didit",
    "didit_client_id": "your_didit_client_id",
    "didit_client_secret": "your_didit_client_secret",
    "onfido_api_key": "your_onfido_api_key",
    "trulioo_api_key":  "your_trulioo_api_key"
  }
}